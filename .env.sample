# unbound-container — .env.sample
# Copy to .env and fill in your values.
# Never commit .env to git — it contains secrets.
#
# github.com/mmBesar/unbound-container

# Timezone — IANA format e.g. Europe/London, America/New_York, Asia/Tokyo
TZ=Africa/Cairo

# Path where container data is stored on the host
CONTAINER_DIR=/srv/docker/cont

# Pi-hole admin password
ADMIN_PASSWORD=changeme
